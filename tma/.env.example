# Тільки корінь: https://<ref>.supabase.co — без /rest/v1/
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Публічний URL бекенду бота (HTTPS), де слухає POST /tma/session — для входу з Telegram без пароля.
# Приклад: https://api.yourdomain.com  або https://xxxx.ngrok-free.app
# VITE_BOT_API_URL=

# Випадаючий «швидкий вхід» на екрані логіну (окрім vite dev за замовчуванням): true / false.
# Тестові паролі лише для seed — для prod не включати.
# VITE_ENABLE_DEV_QUICK_LOGIN=false

