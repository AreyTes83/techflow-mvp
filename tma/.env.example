# Тільки корінь: https://<ref>.supabase.co — без /rest/v1/
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Публічний URL бекенду бота (HTTPS), де слухає POST /tma/session — для входу з Telegram без пароля.
# Приклад: https://api.yourdomain.com  або https://xxxx.ngrok-free.app
# VITE_BOT_API_URL=

# Сховати кнопки швидкого входу з seed (для публічного продакшену).
# За замовчуванням кнопки показані — select у Telegram WebView часто зламаний.
# VITE_DISABLE_SEED_QUICK_LOGIN=true

