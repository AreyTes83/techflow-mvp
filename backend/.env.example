TELEGRAM_TOKEN=
# Якщо бот «мовчить»: 1) процес python main.py має бути запущений постійно на ПК/сервері
# 2) у бота не повинен бути активний webhook (на старті бот викликає deleteWebhook; вручну: .../bot<TOKEN>/deleteWebhook)
# Локально: dev-сервер TMA. Для Telegram з телефона — тільки HTTPS (див. docs/DEPLOY_TMA_TELEGRAM.md)
TMA_URL=http://localhost:5173/
# Приклад продакшену: TMA_URL=https://your-app.vercel.app/
# API URL only: https://<project-ref>.supabase.co  (Supabase → Settings → API → Project URL)
# Do NOT paste the dashboard link https://supabase.com/dashboard/project/...
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Той самий "JWT Secret" що в Supabase → Settings → API (підпис access_token для TMA після перевірки initData).
# Не плутати з anon key / service_role key.
SUPABASE_JWT_SECRET=

# HTTP API бота (initData → JWT). Порт має бути доступний з інтернету (HTTPS через reverse-proxy).
BOT_HTTP_HOST=0.0.0.0
BOT_HTTP_PORT=8787
# Опційно: додаткові дозволені origins для CORS (через кому). Якщо порожньо — береться з TMA_URL + localhost.
# TMA_CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173
# Термін дії виданого access_token (секунди), за замовчуванням 3600.
# TMA_SESSION_TTL_SECONDS=3600

# Postgres password (Dashboard → Database) — лише локально для scripts/apply_mvp_database.py
SUPABASE_DB_PASSWORD=

